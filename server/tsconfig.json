{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "../text-client/src/menu/pages",
    "../text-client/src/menu/menu.ts",
    "../text-client/src/menu/menuAction.ts",
    "../lib/utils"
  ],
  "exclude": ["node_modules"]
}
