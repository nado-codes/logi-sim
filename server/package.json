{
  "name": "logi-sim",
  "version": "0.7.0",
  "description": "A text-based logistics simulator grounded in reality, and implements real market demand and freight transport mechanics",
  "main": "index.js",
  "scripts": {
    "sc-base": "nodemon --watch src,config --ext ts,json --exec ts-node src/scenarios/base-scenario.ts",
    "dev": "nodemon --watch src,config --ext ts,json --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@logisim/lib": "file:../lib",
    "express": "^5.2.1"
  }
}
